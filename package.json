{
  "name": "openclaw-video-call",
  "version": "0.1.7",
  "description": "Your OpenClaw agent calls you with real-time AI video — powered by Runway",
  "type": "module",
  "bin": {
    "openclaw-video-call": "./bin/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build:client": "vite build",
    "build": "npm run build:client && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "preview": "npm run build && npm start",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@runwayml/avatars-react": "^0.8.0",
    "@runwayml/sdk": "^1.0.0",
    "express": "^5.1.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "license": "MIT"
}
